{
  "name": "easystream",
  "version": "0.1.0",
  "private": true,
  "description": "Stream, we'll handle the rest",
  "dependencies": {
    "@emotion/react": "^11.7.0",
    "@emotion/styled": "^11.6.0",
    "@material-ui/icons": "^4.11.2",
    "@microsoft/rush-stack-compiler-3.3": "^0.9.47",
    "@mui/material": "^5.2.3",
    "@mui/styled-engine-sc": "^5.1.0",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.5.0",
    "@testing-library/user-event": "^7.2.1",
    "@types/jest": "^24.9.1",
    "@types/node": "^12.12.50",
    "@types/react": "^17.0.37",
    "@types/react-dom": "^17.0.11",
    "@types/react-ranger": "^2.0.1",
    "@types/react-router": "^5.1.17",
    "@types/react-router-dom": "^5.3.2",
    "@types/styled-components": "^5.1.17",
    "concurrently": "^5.2.0",
    "electron-is-dev": "^1.2.0",
    "electron-webpack": "^2.8.2",
    "electronmon": "^1.1.2",
    "node-sass": "^7.0.0",
    "node-scss": "^7.0.3",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-icons": "^4.3.1",
    "react-ranger": "^2.1.0",
    "react-router-dom": "^6.0.2",
    "react-scripts": "3.4.1",
    "scss": "^0.2.4",
    "semantic-ui-css": "^2.4.1",
    "semantic-ui-react": "^2.0.4",
    "styled-components": "^5.3.3",
    "typescript": "^4.5.4",
    "wait-on": "^5.1.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^6.0.0-beta.61",
    "@electron-forge/maker-deb": "^6.0.0-beta.61",
    "@electron-forge/maker-dmg": "^6.0.0-beta.61",
    "@electron-forge/maker-rpm": "^6.0.0-beta.61",
    "@electron-forge/maker-squirrel": "^6.0.0-beta.61",
    "@electron-forge/maker-wix": "^6.0.0-beta.61",
    "@electron-forge/maker-zip": "^6.0.0-beta.61",
    "electron": "^9.1.0",
    "electron-builder": "^22.7.0",
    "electron-wix-msi": "^3.2.0"
  },
  "optionalDependencies": {
    "babel-loader": "8.1.0"
  },
  "scripts": {
    "start": "concurrently \"BROWSER=none yarn react-start\" \"wait-on http://localhost:3000 && yarn electron-start\"",
    "build": "yarn react-build && npm run electron-build",
    "test": "react-scripts test",
    "compile": "electron-webpack",
    "dist": "yarn compile && electron-builder",
    "dist:dir": "yarn dist --dir -c.compression=store -c.mac.identity=null",
    "eject": "react-scripts eject",
    "package": "react-scripts build && electron-forge package",
    "make": "react-scripts build && electron-forge make",
    "release": "yarn react-build && npm run electron-release",
    "electron-start": "&& electron-forge start",
    "electron-build": "electron-builder",
    "electron-release": "electron-builder --publish=always",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "main": "public/main.js",
  "homepage": "./",
  "compilerOptions": {
    "sourceMap": true
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "src/icons/mac/icon.icns",
        "name": "easystream",
        "asar": true
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "cra_electron_forge_demo"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {}
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {
            "options": {
              "license": "MIT License"
            }
          }
        },
        {
          "name": "@electron-forge/maker-dmg",
          "config": {
            "background": "./src/Assets/icons/png/1024x1024.png",
            "format": "ULFO"
          }
        },
        {
          "name": "@electron-forge/maker-wix",
          "config": {
            "language": 1033,
            "manufacturer": "EasyStream"
          }
        }
      ]
    }
  }
}
